# ── 量化系统环境变量 ──
# 复制此文件为 .env 并填入真实值

# Web 密钥（用于 session 加密，务必修改）
FLASK_SECRET_KEY=your-secret-key-change-me

# 市场数据存储模式（xlsx、shadow 或 csv）
MARKET_STORAGE_MODE=xlsx

# 管理员初始密码（首次启动时创建）
ADMIN_PASSWORD=请修改此密码
USER_PASSWORD=请修改此密码

# 邀请码（用户注册时需要）
INVITE_CODE=请修改此邀请码

# 爬虫认证
CRAWLER_URL=
CRAWLER_USER=
CRAWLER_PASS=

# 邮件通知 (QQ SMTP)
SMTP_USER=
SMTP_PASS=
SMTP_HOST=your-smtp-host
SMTP_PORT=465
NOTIFY_EMAIL=
